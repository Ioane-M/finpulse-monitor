# ─────────────────────────────────────────────────────────────
#  FinPulse – Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the actual .env file to version control.
# ─────────────────────────────────────────────────────────────

# ── Financial Modeling Prep (FMP) ────────────────────────────
# Free API key at: https://financialmodelingprep.com/developer
FMP_API_KEY=your_fmp_api_key_here

# ── Watchlist ─────────────────────────────────────────────────
# Comma-separated ticker symbols (no spaces)
WATCHLIST_SYMBOLS=AAPL,MSFT,GOOGL,TSLA,AMZN,NVDA,META,JPM,V,BRK.B

# ── Alert Settings ────────────────────────────────────────────
# Percentage move threshold to trigger a STRONG signal alert
ALERT_THRESHOLD_PCT=3

# ── Slack ─────────────────────────────────────────────────────
# Incoming Webhook URL from your Slack app
# Guide: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ

# ── Google Sheets ─────────────────────────────────────────────
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ── n8n Instance (optional – for self-hosted setups) ──────────
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
